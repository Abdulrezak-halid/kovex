# Kovex ERP production environment example.
# Copy values into Render/Supabase dashboards. Do not commit real secrets.

NODE_ENV=production
LOG_LEVEL=info

# Render provides PORT for web services. Keep this only for local production
# simulation if needed.
PORT=10000

# Supabase PostgreSQL connection string.
# Use direct connection when reachable; use the Supabase session pooler when
# the host platform requires IPv4.
DATABASE_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Generate a long random value, for example:
# openssl rand -base64 48
AUTH_SECRET=replace-with-a-long-random-secret

# Frontend build values for the same-origin deployment.
BASE_PATH=/
MOCK_API=false
