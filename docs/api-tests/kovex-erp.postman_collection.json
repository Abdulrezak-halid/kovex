    {
      "name": "Health",
      "item": [
        {
          "name": "Health check returns ok",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/healthz"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"returns HTTP 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"response body reports ok status\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property(\"status\", \"ok\");",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Run this folder before protected endpoint folders. The final request logs in again so the rest of the collection has a valid session cookie.",
      "item": [
        {
          "name": "Logout clean slate",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/logout"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"logout is idempotent\", function () {",
                  "  pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Invalid login is rejected",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"invalid@example.com\",\n  \"password\": \"wrong-password\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"invalid credentials return 401\", function () {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test(\"safe login error is returned\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.error).to.eql(\"Invalid email or password\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login with demo user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{demoEmail}}\",\n  \"password\": \"{{demoPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"login returns HTTP 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"login returns a public user\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.user).to.include.keys([\"id\", \"name\", \"email\", \"role\", \"active\"]);",
                  "  pm.expect(json.user.email.toLowerCase()).to.eql(pm.variables.get(\"demoEmail\").toLowerCase());",
                  "  pm.collectionVariables.set(\"currentUserId\", String(json.user.id));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Current user session is readable",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"current session returns HTTP 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"current user matches login user\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(String(json.user.id)).to.eql(pm.collectionVariables.get(\"currentUserId\"));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout clears session",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/logout"
          },
          "event": [
            {
