{
  "name": "workspace",
  "version": "0.0.0",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "preinstall": "node ./scripts/preinstall.mjs",
    "dev": "node ./scripts/dev.mjs",
    "dev:front": "node ./scripts/dev-front.mjs",
    "dev:back": "DATABASE_URL=${DATABASE_URL:-postgres://postgres:postgres@localhost:5432/sme_erp} PORT=${PORT:-5000} pnpm --filter @sme-erp/back run dev",
    "dev:docker": "docker compose -f docker/compose.dev.yml up --build",
    "docker:down": "docker compose -f docker/compose.dev.yml down",
    "dev:web": "pnpm run dev:front",
    "dev:api": "pnpm run dev:back",
    "api:ui": "echo Swagger UI: http://localhost:5000/api-docs/",
    "api:schema": "pnpm --filter @sme-erp/api-contract run codegen",
    "db:push": "DATABASE_URL=${DATABASE_URL:-postgres://postgres:postgres@localhost:5432/sme_erp} pnpm --filter @sme-erp/database run push",
    "db:migrate": "pnpm run db:push",
    "db:seed-admin": "pnpm --filter @sme-erp/database run seed:admin",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter @sme-erp/front --filter @sme-erp/back --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
